<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. We disable both cloud backup and
  device-to-device transfer so user behavioural data is never copied off
  device without an explicit in-app "Cloud sync" action.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
